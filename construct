<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Construct — Melbourne</title>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;700&family=Syne:wght@400;500;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --black: #080808;
    --off-black: #0f0f0f;
    --card: #111111;
    --border: rgba(255,255,255,0.07);
    --border-bright: rgba(255,255,255,0.15);
    --green: #00ff88;
    --green-dim: rgba(0,255,136,0.12);
    --green-glow: rgba(0,255,136,0.04);
    --white: #f0ede8;
    --muted: rgba(240,237,232,0.45);
    --mono: 'JetBrains Mono', monospace;
    --sans: 'Syne', sans-serif;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--black);
    color: var(--white);
    font-family: var(--mono);
    font-size: 14px;
    line-height: 1.7;
    cursor: none;
  }

  /* Custom cursor */
  .cursor {
    width: 8px; height: 8px;
    background: var(--green);
    border-radius: 50%;
    position: fixed;
    pointer-events: none;
    z-index: 9999;
    transform: translate(-50%, -50%);
    transition: transform 0.1s ease, width 0.2s, height 0.2s;
    mix-blend-mode: screen;
  }
  .cursor-ring {
    width: 32px; height: 32px;
    border: 1px solid rgba(0,255,136,0.4);
    border-radius: 50%;
    position: fixed;
    pointer-events: none;
    z-index: 9998;
    transform: translate(-50%, -50%);
    transition: transform 0.15s ease, width 0.2s, height 0.2s, opacity 0.2s;
  }
  body:hover .cursor { opacity: 1; }

  /* Scanline overlay */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0,0,0,0.03) 2px,
      rgba(0,0,0,0.03) 4px
    );
    pointer-events: none;
    z-index: 1000;
  }

  /* NAV */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    padding: 20px 48px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid var(--border);
    background: rgba(8,8,8,0.92);
    backdrop-filter: blur(12px);
  }
  .nav-logo {
    font-family: var(--sans);
    font-size: 18px;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--white);
    text-decoration: none;
  }
  .nav-logo span { color: var(--green); }
  .nav-links {
    display: flex;
    gap: 32px;
    list-style: none;
  }
  .nav-links a {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--muted);
    text-decoration: none;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--green); }
  .nav-cta {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--black);
    background: var(--green);
    padding: 8px 20px;
    text-decoration: none;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 700;
    transition: opacity 0.2s;
  }
  .nav-cta:hover { opacity: 0.85; }

  /* SECTIONS */
  section { padding: 120px 48px; }
  .container { max-width: 1100px; margin: 0 auto; }

  /* HERO */
  #home {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: 140px;
    position: relative;
    overflow: hidden;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }
  .hero-terminal {
    background: var(--card);
    border: 1px solid var(--border);
    padding: 32px;
    position: relative;
  }
  .terminal-bar {
    display: flex;
    gap: 8px;
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--border);
  }
  .t-dot { width: 10px; height: 10px; border-radius: 50%; }
  .t-dot.r { background: #ff5f57; }
  .t-dot.y { background: #febc2e; }
  .t-dot.g { background: #28c840; }
  .terminal-line {
    font-size: 12px;
    line-height: 2;
    color: var(--muted);
  }
  .terminal-line .prompt { color: var(--green); }
  .terminal-line .cmd { color: var(--white); }
  .terminal-line .output { color: rgba(0,255,136,0.6); }
  .terminal-line .dim { color: rgba(240,237,232,0.25); }
  .blink {
    display: inline-block;
    width: 8px; height: 14px;
    background: var(--green);
    vertical-align: middle;
    animation: blink 1s step-end infinite;
    margin-left: 2px;
  }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }

  .hero-content { }
  .hero-tag {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--green);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .hero-tag::before {
    content: '';
    display: block;
    width: 24px; height: 1px;
    background: var(--green);
  }
  h1 {
    font-family: var(--sans);
    font-size: clamp(52px, 7vw, 88px);
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: -0.03em;
    color: var(--white);
    margin-bottom: 28px;
  }
  h1 .accent { color: var(--green); }
  .hero-tagline {
    font-family: var(--mono);
    font-size: 13px;
    color: var(--muted);
    line-height: 1.8;
    margin-bottom: 40px;
    font-style: italic;
  }
  .hero-tagline em { color: var(--white); font-style: normal; }
  .hero-actions { display: flex; gap: 16px; align-items: center; }
  .btn-primary {
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--black);
    background: var(--green);
    padding: 14px 28px;
    text-decoration: none;
    transition: opacity 0.2s;
    display: inline-block;
  }
  .btn-primary:hover { opacity: 0.85; }
  .btn-ghost {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    text-decoration: none;
    padding: 14px 0;
    border-bottom: 1px solid var(--border-bright);
    transition: color 0.2s, border-color 0.2s;
  }
  .btn-ghost:hover { color: var(--white); border-color: var(--white); }

  /* ABOUT */
  #about { background: var(--off-black); }
  .section-label {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--green);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .section-label::before {
    content: '';
    display: block;
    width: 24px; height: 1px;
    background: var(--green);
  }
  h2 {
    font-family: var(--sans);
    font-size: clamp(32px, 4vw, 52px);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.05;
    margin-bottom: 24px;
  }
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
    margin-top: 64px;
  }
  .about-text p {
    font-family: var(--mono);
    font-size: 14px;
    color: var(--muted);
    line-height: 1.9;
    margin-bottom: 20px;
  }
  .about-text p em { color: var(--white); font-style: normal; }
  .about-pillars { display: flex; flex-direction: column; gap: 1px; }
  .pillar {
    border: 1px solid var(--border);
    padding: 28px 32px;
    background: var(--card);
    position: relative;
    transition: border-color 0.2s, background 0.2s;
  }
  .pillar:hover {
    border-color: var(--border-bright);
    background: rgba(0,255,136,0.03);
  }
  .pillar-num {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--green);
    letter-spacing: 0.1em;
    margin-bottom: 8px;
  }
  .pillar-title {
    font-family: var(--sans);
    font-size: 17px;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 6px;
  }
  .pillar-desc {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--muted);
    line-height: 1.7;
  }

  /* EVENTS */
  #events { }
  .events-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 48px;
  }
  .event-card {
    border: 1px solid var(--border);
    background: var(--card);
    display: grid;
    grid-template-columns: 200px 1fr auto;
    align-items: center;
    gap: 48px;
    padding: 36px 40px;
    margin-bottom: 1px;
    transition: border-color 0.2s, background 0.2s;
    text-decoration: none;
    color: inherit;
    cursor: none;
  }
  .event-card:hover {
    border-color: var(--green);
    background: var(--green-glow);
  }
  .event-date {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--green);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    line-height: 1.8;
  }
  .event-title {
    font-family: var(--sans);
    font-size: 22px;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 6px;
    letter-spacing: -0.01em;
  }
  .event-meta {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--muted);
  }
  .event-tag {
    font-family: var(--mono);
    font-size: 11px;
    padding: 6px 14px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 700;
  }
  .event-tag.upcoming { background: var(--green-dim); color: var(--green); }
  .event-tag.past { background: rgba(255,255,255,0.05); color: var(--muted); }
  .events-note {
    margin-top: 32px;
    padding: 24px 32px;
    border: 1px solid var(--border);
    background: var(--card);
    font-family: var(--mono);
    font-size: 12px;
    color: var(--muted);
    line-height: 1.8;
  }
  .events-note .prompt { color: var(--green); }

  /* JOIN */
  #join { background: var(--off-black); }
  .join-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    margin-top: 64px;
  }
  .join-card {
    border: 1px solid var(--border);
    background: var(--card);
    padding: 40px;
    transition: border-color 0.2s;
  }
  .join-card:hover { border-color: var(--border-bright); }
  .join-card.featured { border-color: var(--green); background: var(--green-glow); }
  .join-card-label {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--green);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  .join-card-title {
    font-family: var(--sans);
    font-size: 26px;
    font-weight: 800;
    color: var(--white);
    margin-bottom: 12px;
    letter-spacing: -0.02em;
  }
  .join-card-desc {
    font-family: var(--mono);
    font-size: 13px;
    color: var(--muted);
    line-height: 1.8;
    margin-bottom: 28px;
  }
  .join-card-desc em { color: var(--white); font-style: normal; }
  .join-list {
    list-style: none;
    margin-bottom: 32px;
  }
  .join-list li {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--muted);
    padding: 8px 0;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .join-list li::before {
    content: '→';
    color: var(--green);
    font-size: 11px;
  }
  .join-list li:last-child { border-bottom: none; }

  /* FOOTER */
  footer {
    padding: 48px;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .footer-logo {
    font-family: var(--sans);
    font-size: 16px;
    font-weight: 800;
    letter-spacing: -0.02em;
  }
  .footer-logo span { color: var(--green); }
  .footer-meta {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--muted);
    text-align: right;
    line-height: 1.8;
  }
  .footer-links {
    display: flex;
    gap: 24px;
  }
  .footer-links a {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--muted);
    text-decoration: none;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: color 0.2s;
  }
  .footer-links a:hover { color: var(--green); }

  /* BG grid */
  .bg-grid {
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(0,255,136,0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,255,136,0.02) 1px, transparent 1px);
    background-size: 64px 64px;
    pointer-events: none;
    z-index: 0;
  }
  section, nav, footer { position: relative; z-index: 1; }

  /* Fade in */
  .fade-in {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .fade-in.visible { opacity: 1; transform: none; }

  @media (max-width: 900px) {
    nav { padding: 16px 24px; }
    .nav-links { display: none; }
    section { padding: 80px 24px; }
    footer { padding: 32px 24px; flex-direction: column; gap: 24px; text-align: center; }
    .footer-meta { text-align: center; }
    .hero-grid, .about-grid, .join-grid { grid-template-columns: 1fr; gap: 40px; }
    .event-card { grid-template-columns: 1fr; gap: 16px; }
    h1 { font-size: 48px; }
  }
</style>
</head>
<body>

<div class="bg-grid"></div>
<div class="cursor" id="cursor"></div>
<div class="cursor-ring" id="cursorRing"></div>

<nav>
  <a href="#home" class="nav-logo">Construct<span>.</span></a>
  <ul class="nav-links">
    <li><a href="#about">About</a></li>
    <li><a href="#events">Events</a></li>
    <li><a href="#join">Join</a></li>
  </ul>
  <a href="#join" class="nav-cta">Join Slack →</a>
</nav>

<!-- HERO -->
<section id="home">
  <div class="container">
    <div class="hero-grid">
      <div class="hero-content fade-in">
        <div class="hero-tag">Melbourne — Hardware Community</div>
        <h1>Con<span class="accent">struct</span></h1>
        <p class="hero-tagline"><em>"All great technology starts as science fiction."</em></p>
        <p style="font-family:var(--mono);font-size:13px;color:var(--muted);line-height:1.9;margin-bottom:40px;">
          Melbourne's community for hardware founders and deep tech builders.
          We meet monthly at Colab to show what we're making, get honest feedback, and build real relationships.
        </p>
        <div class="hero-actions">
          <a href="#join" class="btn-primary">Join the community</a>
          <a href="#events" class="btn-ghost">See next event →</a>
        </div>
      </div>
      <div class="hero-terminal fade-in" style="transition-delay:0.2s">
        <div class="terminal-bar">
          <div class="t-dot r"></div>
          <div class="t-dot y"></div>
          <div class="t-dot g"></div>
        </div>
        <div class="terminal-line"><span class="prompt">→</span> <span class="dim">construct.melbourne</span></div>
        <div class="terminal-line"><span class="prompt">→</span> <span class="cmd">init community --location=colab --type=hardware</span></div>
        <div class="terminal-line"><span class="output">✓ Community initialised</span></div>
        <div class="terminal-line"><span class="output">✓ Venue locked: Colab, Melbourne</span></div>
        <div class="terminal-line"><span class="output">✓ First event loading...</span></div>
        <div class="terminal-line" style="margin-top:8px"><span class="prompt">→</span> <span class="cmd">members.list()</span></div>
        <div class="terminal-line"><span class="output">Hardware founders</span></div>
        <div class="terminal-line"><span class="output">Deep tech builders</span></div>
        <div class="terminal-line"><span class="output">Early stage operators</span></div>
        <div class="terminal-line" style="margin-top:8px"><span class="prompt">→</span> <span class="dim">awaiting input</span><span class="blink"></span></div>
      </div>
    </div>
  </div>
</section>

<!-- ABOUT -->
<section id="about">
  <div class="container">
    <div class="section-label">About</div>
    <h2>A loading program<br>for real things.</h2>
    <div class="about-grid">
      <div class="about-text fade-in">
        <p>
          In The Matrix, the Construct is the white room — a blank space where anything can be loaded, tested, and built before it enters the real world. That's what we're building in Melbourne.
        </p>
        <p>
          <em>Construct</em> is a monthly gathering for hardware founders, deep tech operators, and the people building physical things. We meet at Colab, Melbourne's hardware maker space, to show work-in-progress, get honest feedback, and find the people worth building alongside.
        </p>
        <p>
          No investors in the room. No decks required. Just founders and builders who take making seriously.
        </p>
        <p>
          This is not a networking event. It's a community — and communities are built slowly, with the right people, in the right room.
        </p>
      </div>
      <div class="about-pillars fade-in" style="transition-delay:0.15s">
        <div class="pillar">
          <div class="pillar-num">01 //</div>
          <div class="pillar-title">Show your work</div>
          <div class="pillar-desc">Monthly show and tell. Bring a prototype, a problem, or an idea. No polish required — the room rewards honesty.</div>
        </div>
        <div class="pillar">
          <div class="pillar-num">02 //</div>
          <div class="pillar-title">Build real relationships</div>
          <div class="pillar-desc">Small, curated, consistent. The same people show up every month. Trust compounds over time.</div>
        </div>
        <div class="pillar">
          <div class="pillar-num">03 //</div>
          <div class="pillar-title">Operate at the frontier</div>
          <div class="pillar-desc">Hardware is hard. The people in this room are doing it anyway. That's the only qualification that matters.</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- EVENTS -->
<section id="events">
  <div class="container">
    <div class="events-header">
      <div>
        <div class="section-label">Events</div>
        <h2>Load sessions.</h2>
      </div>
    </div>

    <a href="#join" class="event-card fade-in">
      <div class="event-date">
        Coming soon<br>
        Melbourne, VIC<br>
        Colab HQ
      </div>
      <div>
        <div class="event-title">Construct #001 — Show &amp; Tell</div>
        <div class="event-meta">First hardware show and tell night · 15–20 founders · Doors 6pm · No decks</div>
      </div>
      <div class="event-tag upcoming">Upcoming</div>
    </a>

    <div class="events-note fade-in">
      <span class="prompt">// </span>Events are invite-only for now. Join the Slack to get access to future load sessions, the community calendar, and direct invites from the team.
    </div>
  </div>
</section>

<!-- JOIN -->
<section id="join">
  <div class="container">
    <div class="section-label">Join</div>
    <h2>Enter the room.</h2>
    <p style="font-family:var(--mono);font-size:13px;color:var(--muted);line-height:1.9;max-width:560px;margin-top:16px;">
      Construct is kept deliberately small and high-signal. We're not trying to build a big community — we're trying to build the right one.
    </p>
    <div class="join-grid">
      <div class="join-card featured fade-in">
        <div class="join-card-label">// Recommended</div>
        <div class="join-card-title">Join the Slack</div>
        <div class="join-card-desc">
          The Construct Slack is where the community lives between events. <em>Share what you're building, ask hard questions, find collaborators.</em>
        </div>
        <ul class="join-list">
          <li>Access to the community channel</li>
          <li>Direct invites to monthly events</li>
          <li>Founder intros and warm connections</li>
          <li>Hardware resources and deal flow</li>
        </ul>
        <a href="YOUR_SLACK_INVITE_LINK" class="btn-primary">Join Slack →</a>
      </div>
      <div class="join-card fade-in" style="transition-delay:0.1s">
        <div class="join-card-label">// Events</div>
        <div class="join-card-title">Attend a load session</div>
        <div class="join-card-desc">
          Monthly show and tell nights at Colab. <em>Bring something you're building — prototype, problem, or half-baked idea.</em> The room will help.
        </div>
        <ul class="join-list">
          <li>Monthly at Colab, Melbourne</li>
          <li>15–20 founders per session</li>
          <li>No investors unless invited</li>
          <li>No decks, no pitching</li>
        </ul>
        <a href="#events" class="btn-ghost">See upcoming events →</a>
      </div>
    </div>
  </div>
</section>

<footer>
  <div class="footer-logo">Construct<span>.</span></div>
  <div class="footer-links">
    <a href="#about">About</a>
    <a href="#events">Events</a>
    <a href="#join">Join</a>
  </div>
  <div class="footer-meta">
    Melbourne, Australia<br>
    Hosted at Colab · Est. 2026
  </div>
</footer>

<script>
  // Cursor
  const cursor = document.getElementById('cursor');
  const ring = document.getElementById('cursorRing');
  let mx = 0, my = 0, rx = 0, ry = 0;
  document.addEventListener('mousemove', e => { mx = e.clientX; my = e.clientY; });
  function animateCursor() {
    cursor.style.left = mx + 'px'; cursor.style.top = my + 'px';
    rx += (mx - rx) * 0.12; ry += (my - ry) * 0.12;
    ring.style.left = rx + 'px'; ring.style.top = ry + 'px';
    requestAnimationFrame(animateCursor);
  }
  animateCursor();
  document.querySelectorAll('a, button').forEach(el => {
    el.addEventListener('mouseenter', () => { cursor.style.width = '14px'; cursor.style.height = '14px'; ring.style.opacity = '0'; });
    el.addEventListener('mouseleave', () => { cursor.style.width = '8px'; cursor.style.height = '8px'; ring.style.opacity = '1'; });
  });

  // Fade in on scroll
  const observer = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.1 });
  document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));
</script>
</body>
</html>
